\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{cv-tagged-ia}[2026/06/22 Tagged B/W minimalist CV style (XeLaTeX)]

% =====================================================================
% cv-tagged-ia.sty -- Black/white minimalist single-column CV style
% ---------------------------------------------------------------------
% Engine:   XeLaTeX (required)
% Layout:   single column, with local sub-columns inside entries
% Font:     Lato (fallback Fira Sans) via fontspec; mono Inconsolata
% Icons:    fontawesome5
% Signature look: section headings are a solid BLACK "tag" rectangle
%                 containing WHITE uppercase bold text, left-aligned.
%
% PUBLIC API
% ---------------------------------------------------------------------
%   \cvtopbanner                          -- no-op (kept for API parity)
%   \cvcontact{icon}{text}                -- icon-chip + text pair
%   \cvname{firstline}{secondline}        -- two stacked huge caps lines
%   \cvsummary{text}                      -- justified intro paragraph
%   \cvsection{TITLE}                     -- black tag heading
%   \cvsidesection{TITLE}                 -- alias of \cvsection
%   \cventry{title}{date}{employer}{desc} -- entry row (date col + main)
%   \cvsubentry{date}{title}{desc}        -- nested sub-project
%   \cvchip{label}                        -- simple boxed label
%   \cvchiprow{comma,labels}              -- row of boxed labels
%   \cvskillgroup{heading}{body}          -- bold heading + body
%   \cvlanguage{name}{sublabel}{level}    -- plain "name -- sublabel"
%   \cvsidelist{items}                    -- plain bullet list
%   \cvruled                              -- thin separator (minimal)
%   \cvtechstack{a / b / c}               -- monospace slash-joined line
%   \cvskillbar{label}{frac}              -- solid black bar, frac of max
%   \cvskillbubbles{l1/w1, l2/w2, ...}    -- row of black circles + labels
% =====================================================================

% --- Engine guard ----------------------------------------------------
\RequirePackage{iftex}
\RequireXeTeX

% --- Required packages -----------------------------------------------
\RequirePackage{fontspec}
\RequirePackage[a4paper,top=1.4cm,bottom=1.2cm,left=1.6cm,right=1.6cm]{geometry}
\RequirePackage{xcolor}
\RequirePackage{graphicx}
\RequirePackage{tikz}
\RequirePackage{fontawesome5}
\RequirePackage{enumitem}
\RequirePackage{microtype}
\RequirePackage{calc}
\RequirePackage{array}
\RequirePackage{tabularx}
\RequirePackage{multicol}
\RequirePackage{etoolbox}
\RequirePackage[hidelinks]{hyperref}

\usetikzlibrary{calc}

% --- Color palette (strict B/W minimalism) ---------------------------
\definecolor{cvText}{HTML}{1A1A1A}   % near-black body text
\definecolor{cvBlack}{HTML}{0D0D0D}  % black fills / chips / tags
\definecolor{cvMuted}{HTML}{555555}  % muted secondary text
\definecolor{cvRule}{HTML}{1A1A1A}

\color{cvText}
\pagecolor{white}

% --- Fonts -----------------------------------------------------------
% Body / headings: humanist sans -- prefer Lato, fall back to Fira Sans.
\IfFontExistsTF{Lato}{%
  \setmainfont{Lato}%
  \setsansfont{Lato}%
}{%
  \IfFontExistsTF{Fira Sans}{%
    \setmainfont{Fira Sans}%
    \setsansfont{Fira Sans}%
  }{%
    % last-resort: stick with default Latin Modern
  }%
}
\renewcommand{\familydefault}{\sfdefault}

% Monospace for tech-stack lines: prefer a system "Inconsolata"; if that
% is not discoverable (common on TeX Live, where it ships as the OTF
% "Inconsolatazi4"), load that OTF directly via fontspec; then fall back
% to Fira Mono, then to the default \ttfamily. This keeps tech-stack
% lines truly monospaced under XeLaTeX (the inconsolata.sty package sets
% an OT1-only \ttdefault that fontspec cannot map, so it is avoided).
\IfFontExistsTF{Inconsolatazi4-Regular.otf}{%
  \setmonofont{Inconsolatazi4-Regular.otf}%  Inconsolata as shipped by TeX Live
}{%
  \IfFontExistsTF{Inconsolata}{%
    \setmonofont{Inconsolata}%  system-installed Inconsolata
  }{%
    \IfFontExistsTF{Fira Mono}{%
      \setmonofont{Fira Mono}%
    }{%
      % keep default typewriter family (Latin Modern Mono)
    }%
  }%
}

% Small-caps family for the tech-stack line. Lato ships NO small-caps face
% (\scshape silently falls back to the regular shape), so we load a real
% small-caps-capable family via fontspec's OpenType "Letters=SmallCaps"
% feature: TeX Gyre Heros (a Helvetica-class humanist sans that harmonises
% with Lato) is preferred; Latin Modern Roman is the last-resort fallback.
% Both ship with the TeX Live image, so the CI build always has true SC.
\IfFontExistsTF{TeX Gyre Heros}{%
  \newfontfamily\cvscfont{TeX Gyre Heros}[Letters=SmallCaps]%
}{%
  \newfontfamily\cvscfont{Latin Modern Roman}[Letters=SmallCaps]%
}

% --- hyperref ---------------------------------------------------------
\hypersetup{
  colorlinks=true,
  linkcolor=cvText,
  urlcolor=cvText,
  citecolor=cvText,
  pdfborder={0 0 0}
}

% --- List styling -----------------------------------------------------
% Square box bullets (a small filled \rule for crisp, size-controlled
% markers) with generous inter-item spacing so individual bullets breathe.
\newcommand{\cv@sqbullet}{\raisebox{0.18ex}{\rule{0.5em}{0.5em}}}
\setlist{leftmargin=1.4em}
\setlist[itemize,1]{label=\cv@sqbullet,labelsep=.6em,
  topsep=0.35em,itemsep=0.45em,parsep=0.1em}
\setlist[itemize,2]{label=\cv@sqbullet,labelsep=.5em,leftmargin=1.3em,
  topsep=0.3em,itemsep=0.35em,parsep=0.1em}

% --- Layout dimensions ------------------------------------------------
\newlength{\cv@datecol}
\setlength{\cv@datecol}{0.18\linewidth}
\newlength{\cv@barmax}
\setlength{\cv@barmax}{4.2cm}
\newlength{\cv@barlabel}
\setlength{\cv@barlabel}{4.6cm}

% --- \cvskillscompact -------------------------------------------------
% Shrink the skill-bar geometry so the Skills section fits a narrow
% column (e.g. the right column of the two-column header). Call it once
% before the skills content is emitted; it also narrows the bubble step.
% Idempotent enough for a single header use; scope it in a group if a
% later full-width skills block is rendered in the same document.
\newcommand{\cvskillscompact}{%
  \setlength{\cv@barmax}{2.3cm}%
  \setlength{\cv@barlabel}{2.7cm}%
  \setlength{\cv@bubblestep}{0.92cm}%
  \cv@barlabelledfalse  % suppress the bar's text label (group name repeats
                        % immediately below via \cvskillgroup)
  \cv@bubblefittrue     % shrink the concept-bubble row to the column width
}

% =====================================================================
%  PUBLIC API
% =====================================================================

% --- \cvtopbanner ----------------------------------------------------
% No-op: this minimalist style has a pure white background.
\newcommand{\cvtopbanner}{}

% --- \cvname{firstline}{secondline} ----------------------------------
% Two stacked HUGE BOLD ALL-CAPS lines (condensed leading), then a
% regular sentence-case job-title line passed as #2.
\newcommand{\cvname}[2]{%
  {\bfseries\fontsize{34pt}{34pt}\selectfont\MakeUppercase{#1}}\par
  {\bfseries\fontsize{34pt}{36pt}\selectfont\MakeUppercase{#2}}\par
  \vspace{0.6em}%
}

% --- Private: black rounded-square icon chip with white glyph --------
% Fixed-size square chip: every icon (\faMapMarker, \faLinkedin, \faGithub,
% \faPhone, \faAt, ...) is drawn in an identical 1.5em square box regardless
% of its glyph bounding box, so the meta-section markers all match in size.
\newlength{\cv@chipside}\setlength{\cv@chipside}{1.5em}
\newcommand{\cv@iconchip}[1]{%
  \tikz[baseline=-0.55ex]{%
    \node[rounded corners=2pt,fill=cvBlack,inner sep=0pt,
          minimum width=\cv@chipside,minimum height=\cv@chipside,
          align=center,text=white,font=\scriptsize] {#1};%
  }%
}

% --- \cvcontact{icon}{text} ------------------------------------------
% One icon-chip + text pair. Designed to be placed inside a 2-col grid
% (see main document) but also works standalone.
\newcommand{\cvcontact}[2]{%
  \cv@iconchip{#1}\hspace{0.6em}{\small #2}%
}

% --- \cvsummary{text} ------------------------------------------------
\newcommand{\cvsummary}[1]{%
  {\small #1\par}\vspace{0.6em}%
}

% --- \cvsection{TITLE} -----------------------------------------------
% SIGNATURE: solid black rectangle "tag" with white uppercase bold text.
\newcommand{\cvsection}[1]{%
  \vspace{0.8em}\par\noindent
  \colorbox{cvBlack}{%
    \hspace{0.15em}\rule{0pt}{1.15em}%
    \textcolor{white}{\bfseries\MakeUppercase{#1}}%
    \hspace{0.15em}%
  }%
  \par\vspace{0.5em}%
}

% --- \cvsidesection{TITLE} -- alias ----------------------------------
\newcommand{\cvsidesection}[1]{\cvsection{#1}}

% --- \cventry{title}{date}{employer}{desc} ---------------------------
% Left column (~18%) = date at top; main column = title (left) +
% employer (right, smaller bold); then justified description.
% The date column and the main column are both top-aligned [t]; a shared
% \strut on the first line of each minipage pins them to a common first
% baseline so the date (e.g. "09/2013 --- 08/2010") lines up exactly with
% the entry's title headline rather than floating a hair above it.
\newcommand{\cventry}[4]{%
  \vspace{0.3em}\par\noindent
  \begin{minipage}[t]{\cv@datecol}%
    \raggedright{\strut\small\color{cvMuted}#2}%
  \end{minipage}%
  \hfill
  \begin{minipage}[t]{\dimexpr\linewidth-\cv@datecol-0.4em\relax}%
    {\noindent\strut\textbf{#1}\hfill{\bfseries\small #3}\par}%
    \ifblank{#4}{}{\vspace{0.15em}{\small #4\par}}%
  \end{minipage}%
  \par\vspace{1.1em}%
}

% --- \cvsubentry{date}{title}{desc} ----------------------------------
\newcommand{\cvsubentry}[3]{%
  \vspace{0.15em}\par\noindent
  \begin{minipage}[t]{\cv@datecol}%
    \raggedright{\small\color{cvMuted}\strut #1}%
  \end{minipage}%
  \hfill
  \begin{minipage}[t]{\dimexpr\linewidth-\cv@datecol-0.4em\relax}%
    {\small\strut\textit{#2}\par}%
    \begingroup
      \setlist[itemize,1]{label=\cv@sqbullet,leftmargin=1.4em,labelsep=.5em,%
        topsep=0.25em,itemsep=0.35em,parsep=0.1em}%
      {\small #3}%
    \endgroup
  \end{minipage}%
  \par\vspace{0.35em}%
}

% --- \cvchip{label} / \cvchiprow{labels} -----------------------------
\newcommand{\cvchip}[1]{%
  \tikz[baseline=(c.base)]{%
    \node[draw=cvBlack,line width=0.5pt,inner xsep=6pt,inner ysep=3pt,
          font=\small,text=cvText] (c) {#1};%
  }%
}
\newcommand{\cvchiprow}[1]{%
  \begingroup
  \def\@cvchipsep{}%
  \@for\@chip:=#1\do{%
    \@cvchipsep\cvchip{\@chip}%
    \def\@cvchipsep{\hspace{0.4em}}%
  }%
  \par\medskip
  \endgroup
}

% --- \cvskillgroup{heading}{body} ------------------------------------
% Layout: the group heading and its proficiency bar share ONE line
% (heading left, bar right-aligned in a fixed \cv@barmax column); the
% comma-joined item list follows on the next line. The bar fraction is
% stashed by the preceding \cvskillbar call (\cv@pendingfrac); if no bar
% was stashed (\cv@pendingfrac empty) only the heading is shown.
\def\cv@pendingfrac{}%
\newcommand{\cvskillgroup}[2]{%
  \vspace{0.25em}\par\noindent
  {\bfseries\small #1}%
  \ifx\cv@pendingfrac\@empty\else
    \hfill
    \begin{tikzpicture}[baseline=-0.55ex]
      \draw[cvMuted,line width=0.3pt] (0,0) rectangle (\cv@barmax,0.5em);
      \fill[cvBlack] (0,0) rectangle ({\cv@pendingfrac*\cv@barmax},0.5em);
    \end{tikzpicture}%
    \global\let\cv@pendingfrac\@empty
  \fi
  \par
  {\small #2}\par
  \vspace{0.25em}%
}

% --- \cvskillgroupheading{group} / \cvskillitembar{name}{frac} -------
% Per-item skills layout used by the tagged style: the cv/parse emitter
% writes one \cvskillgroupheading per group followed by one
% \cvskillitembar per item. The heading is a bold group label; each item
% is a name (left, in a fixed label box) with an inline proficiency bar
% (right) whose fill is frac (0..1) of the \cv@barmax track. The bar track
% is right-aligned to the column edge so all bars share a common axis
% regardless of label width.
\newcommand{\cvskillgroupheading}[1]{%
  \par\vspace{0.45em}\noindent
  {\bfseries\small #1}\par
  \vspace{0.2em}%
}
\newcommand{\cvskillitembar}[2]{%
  \par\noindent
  \makebox[\cv@barlabel][l]{\small #1}\hfill
  \begin{tikzpicture}[baseline=-0.55ex]
    \draw[cvMuted,line width=0.3pt] (0,0) rectangle (\cv@barmax,0.5em);
    \fill[cvBlack] (0,0) rectangle ({#2*\cv@barmax},0.5em);
  \end{tikzpicture}%
  \par\vspace{0.2em}%
}

% --- \cvlanguage{name}{sublabel}{level} ------------------------------
% Plain text "name -- sublabel" (no widget). #3 (level) ignored.
\newcommand{\cvlanguage}[3]{%
  \noindent{\bfseries\small #1}\,{\small\color{cvMuted}--- #2}\par
  \vspace{0.2em}%
}

% --- \cvsidelist{items} ----------------------------------------------
% Plain bullet list. Empty-safe.
\newcommand{\cvsidelist}[1]{%
  \ifblank{#1}{}{%
    \begingroup
    \begin{itemize}
      #1
    \end{itemize}
    \endgroup
  }%
}

% --- \cvinterest{icon}{text} -----------------------------------------
% A single interest row inside a \cvsidelist itemize: an \item whose bullet
% is the FontAwesome glyph named by #1 (the bare control-sequence name, e.g.
% "faBicycle", which we turn into \faBicycle via \csname). When #1 is empty
% we fall back to the default square bullet. The icon is tinted with the
% accent-muted colour so it reads as a bullet, not body text.
\newcommand{\cvinterest}[2]{%
  \item[{\ifblank{#1}{\cv@sqbullet}{%
    \color{cvMuted}\csname #1\endcsname}}]%
  {\small #2}%
}

% --- \cvruled --------------------------------------------------------
\newcommand{\cvruled}{%
  \par\vspace{0.4em}{\color{cvRule}\hrule height 0.3pt}\par\vspace{0.4em}%
}

% --- \cvtechstack{a / b / c} -----------------------------------------
% Small-caps technology line, prefixed inline by a small bold "TECH STACK"
% label with a generous gap, all on one line (wrapping naturally if long).
% The cv/parse emitter joins tags with a SPACED " / " separator while any
% intra-tag slash (e.g. "Unix/Linux", "LISP/Clojure") is unspaced; we
% therefore split on the spaced separator only and re-join the tags with a
% centered dot, leaving intra-tag slashes untouched. The whole block is
% indented to line up with the \cventry main column (left margin + date
% column + the 0.4em gutter) so it sits flush under the entry text instead
% of spilling left under the timeline/date column.
%
% \cv@dotjoin recurses over the " / "-delimited list: it prints the head
% tag, then if a separator remains prints a centered dot and recurses on
% the tail. A trailing sentinel " / \cv@dotstop" marks the end.
\newcommand{\cv@dotsep}{\;\textperiodcentered\;}
\def\cv@dotstop{\cv@dotstop}%  unique sentinel token
\def\cv@dotjoin#1 / #2\@nil{%
  #1%
  \ifx\cv@dotstop#2\else\cv@dotsep\cv@dotjoin#2\@nil\fi
}
\newcommand{\cvtechstack}[1]{%
  \par\noindent
  \hspace*{\dimexpr\cv@datecol+0.4em\relax}%
  \begin{minipage}[t]{\dimexpr\linewidth-\cv@datecol-0.4em\relax}%
    \raggedright
    {\footnotesize\bfseries\color{cvMuted}\MakeUppercase{Tech Stack}}%
    \hspace{1.5em}%
    % Lowercase the tags before the small-caps family renders them: true
    % small caps need lowercase input (uppercase letters stay full caps),
    % so \MakeLowercase turns "Azure" into "azure" -> small-caps "azure".
    {\small\cvscfont\MakeLowercase{\cv@dotjoin#1 / \cv@dotstop\@nil}}%
  \end{minipage}%
  \par\vspace{0.3em}%
}

% --- \cvskillbar{label}{frac} ----------------------------------------
% Default (wide) layout: left label box of width \cv@barlabel, then a solid
% black bar of length frac*max. In compact mode (\cvskillscompact) the text
% label is suppressed and only the bar is drawn: the skills template repeats
% the group name immediately below via \cvskillgroup, so a narrow column
% would otherwise overlap the label with the bar. frac is in 0..1.
\newif\ifcv@barlabelled
\cv@barlabelledtrue
\newcommand{\cvskillbar}[2]{%
  \ifcv@barlabelled
    % Wide/standalone layout (other styles): label box + bar on its own line.
    \par\noindent
    \makebox[\cv@barlabel][l]{\small #1}\hspace{0.6em}%
    \begin{tikzpicture}[baseline=-0.55ex]
      \draw[cvMuted,line width=0.3pt] (0,0) rectangle (\cv@barmax,0.55em);
      \fill[cvBlack] (0,0) rectangle ({#2*\cv@barmax},0.55em);
    \end{tikzpicture}%
    \par\vspace{0.3em}%
  \else
    % Compact (header) layout: don't draw here; stash the fraction so the
    % immediately-following \cvskillgroup can render the bar inline next to
    % the group heading. The label #1 is dropped (the group name repeats it).
    \global\def\cv@pendingfrac{#2}%
  \fi
}

% --- \cvskillbubbles{l1;w1, l2;w2, ...} ------------------------------
% Row of solid black circles, radius scaled by weight, with a diagonal
% label above each circle. Pairs are separated by ',' and each pair's
% label/weight by ';' (so labels may freely contain '/'). Labels are
% rotated 40 degrees and anchored at the bubble centre so neighbouring
% labels of varied length do not collide. The horizontal advance is a
% fixed, generous step to keep the row evenly spaced and overlap-free.
\newlength{\cv@bubblestep}
\setlength{\cv@bubblestep}{1.15cm}
% When true (set by \cvskillscompact) the bubble row is shrunk to the
% current \linewidth so a long concept cloud cannot overflow a narrow
% column; the diagonal labels scale with it.
\newif\ifcv@bubblefit
\newcommand{\cvskillbubbles}[1]{%
  \par\vspace{0.4em}\noindent
  \ifcv@bubblefit\resizebox{\linewidth}{!}{%
  \else\leavevmode\fi
    \begin{tikzpicture}[baseline=0pt]
      \def\cv@bx{0}%
      \foreach \pair in {#1}{%
        \edef\cv@tmp{\pair}%
        \expandafter\cv@parsebubble\cv@tmp\@nil
      }%
    \end{tikzpicture}%
  \ifcv@bubblefit}\fi
  \par\vspace{0.3em}%
}
% Parse "label;weight": draw a weight-scaled circle and a 40-degree
% diagonal label above it. Bubble centres advance by a fixed step so the
% layout stays even regardless of individual label widths.
\def\cv@parsebubble#1;#2\@nil{%
  \pgfmathsetmacro{\cv@rad}{0.06 + 0.045*#2}% radius in cm, weight-scaled
  \pgfmathsetmacro{\cv@cx}{\cv@bx + \cv@rad}%
  \fill[cvBlack] (\cv@cx,0) circle (\cv@rad cm);
  \node[font=\scriptsize,anchor=west,rotate=40,inner sep=1.5pt]
    at (\cv@cx,{\cv@rad + 0.12}) {\strut #1};%
  \pgfmathsetmacro{\cv@bxnext}{\cv@bx + \cv@rad +
    \cv@bubblestep/1cm}%
  \xdef\cv@bx{\cv@bxnext}%
}

% --- \cvheatmap{lon/lat/weight, lon/lat/weight, ...} -----------------
% Conference "location heatmap": a REAL equirectangular world map
% (images/worldmap.pdf -- public-domain BlankMap-World-Equirectangular,
% vectorised to PDF) overlaid with a solid black dot per location whose
% radius scales with the weight (visit count). Overlapping dots are
% semi-opaque so dense locations read darker ("heat").
%
% Calibration of images/worldmap.pdf (704.81 x 357.546 pt): the image box
% spans longitude -180..180 and latitude +83.6..-90 (the standard blank
% map trims the far north; Antarctica fills the bottom strip). Dots are
% projected linearly into the image box accordingly. The map width is the
% settable length \cv@mapw (default \linewidth); the height follows the
% asset's fixed aspect ratio so the projection always registers.
\newlength{\cv@mapw}\setlength{\cv@mapw}{\linewidth}
\def\cv@mapaspect{0.50729}%  height/width of images/worldmap.pdf (357.546/704.81)
\def\cv@maplatmax{83.6}%     top edge latitude of the map image
\def\cv@maplatmin{-90}%      bottom edge latitude of the map image
\newcommand{\cvheatmap}[1]{%
  \par\vspace{0.4em}\noindent
  % Resolve the map box into plain pt numbers usable in pgfmath (a length
  % register reads as its pt value); the picture uses x=1pt,y=1pt so these
  % become coordinate units.
  \pgfmathsetmacro{\cv@mapwpt}{\cv@mapw/1pt}%
  \pgfmathsetmacro{\cv@maphpt}{\cv@mapwpt*\cv@mapaspect}%
  \begin{tikzpicture}[x=1pt,y=1pt,baseline=0pt]
    % Real world map, anchored bottom-left at the origin, sized to \cv@mapw.
    \node[anchor=south west,inner sep=0] at (0,0)
      {\includegraphics[width=\cv@mapw]{worldmap}};
    % Location dots, weight-scaled, semi-opaque so overlaps darken.
    \begin{scope}[cvBlack]
      \foreach \pt in {#1}{%
        \edef\cv@tmp{\pt}%
        \expandafter\cv@parseheat\cv@tmp\@nil
      }%
    \end{scope}
  \end{tikzpicture}%
  \par\vspace{0.4em}%
}
% Parse "lon/lat/weight": draw a weight-scaled, semi-opaque dot. Coordinates
% and radius are bare numbers, scaled by the picture's x=1pt,y=1pt unit.
% Projection: lon -180..180 -> 0..mapw; lat latmin..latmax -> 0..maph.
% Divide before multiplying to stay under pgfmath's ~16384 ceiling.
\def\cv@parseheat#1/#2/#3\@nil{%
  \pgfmathsetmacro{\cv@hr}{1.2 + 0.8*#3}% dot radius (pt units), weight-scaled
  \pgfmathsetmacro{\cv@dx}{\cv@mapwpt*(((#1)+180)/360)}%
  \pgfmathsetmacro{\cv@dy}{\cv@maphpt*((#2-(\cv@maplatmin))/%
    (\cv@maplatmax-(\cv@maplatmin)))}%
  \fill[opacity=0.8] (\cv@dx,\cv@dy) circle (\cv@hr);%
}

% --- \cvconfentry{title}{date}{location} -----------------------------
% Compact conference-list row for the column NEXT TO the world map: a tight
% one-line "date — title (location)" at footnotesize, much denser than the
% generic \cventry. The template \let\cventry=\cvconfentry inside the
% conferences block so the cv/parse-emitted \cventry calls render compactly
% without any emitter change. #4 (unused desc) is swallowed for arity parity.
\newcommand{\cvconfentry}[4]{%
  \par\noindent
  {\footnotesize\color{cvMuted}#2}\hspace{0.4em}%
  {\footnotesize #1}%
  \ifblank{#3}{}{{\footnotesize\color{cvMuted}\space---\space#3}}%
  \par\vspace{0.35em}%
}

\endinput

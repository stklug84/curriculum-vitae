\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{cv-sidebar}[2026/05/16 Sidebar CV style (XeLaTeX)]

% =====================================================================
% cv-sidebar.sty -- Two-column sidebar CV style for XeLaTeX
% ---------------------------------------------------------------------
% Engine:   XeLaTeX (required)
% Layout:   30% sidebar / 70% main column via paracol
% Font:     Fira Sans (via fontspec)
% Icons:    fontawesome5
%
% PUBLIC API
% ---------------------------------------------------------------------
%   \cvtopbanner                         -- dark banner at page top (call once)
%   \cvphoto{path}[width]                -- sidebar photo, rounded corners
%   \cvcontact{icon}{text}               -- one contact row (icon = \fa...)
%   \cvname{firstline}{secondline}       -- main column name+role header
%   \cvsummary{text}                     -- opening summary paragraph
%   \cvsection{TITLE}                    -- main heading with accent bar
%   \cvsidesection{TITLE}                -- sidebar heading (no accent bar)
%   \cventry{title}{date}{employer}{desc}-- job/education entry
%   \cvsubentry{date}{title}{desc}       -- nested sub-project
%   \cvchip{label}                       -- rounded pill (single chip)
%   \cvchiprow{labels}                   -- stack of chips (comma-separated)
%   \cvskillgroup{heading}{body}         -- sidebar skill category
%   \cvlanguage{name}{sublabel}{level}   -- language row + 5-dot rating
%   \cvsidelist{items}                   -- plain bullet list (sidebar)
%   \cvruled                             -- thin dotted separator
%
% USAGE
% ---------------------------------------------------------------------
%   \documentclass[a4paper,10pt]{article}
%   \usepackage{cv-sidebar}
%   \begin{document}
%   \cvtopbanner
%   \begin{paracol}{2}
%     % sidebar content (column 1) ...
%     \switchcolumn
%     % main content (column 2) ...
%   \end{paracol}
%   \end{document}
% =====================================================================

% --- Engine guard ----------------------------------------------------
\RequirePackage{iftex}
\RequireXeTeX

% --- Required packages -----------------------------------------------
\RequirePackage{fontspec}
\RequirePackage[sfdefault]{FiraSans}
\RequirePackage[a4paper,top=1.8cm,bottom=1.2cm,left=1.2cm,right=1.2cm]{geometry}
\RequirePackage{xcolor}
\RequirePackage{paracol}
\RequirePackage{tikz}
\RequirePackage{fontawesome5}
\RequirePackage{enumitem}
\RequirePackage{microtype}
\RequirePackage{calc}
\RequirePackage{array}
\RequirePackage{tabularx}
\RequirePackage{etoolbox}
\RequirePackage{eso-pic}
\RequirePackage[hidelinks]{hyperref}

\usetikzlibrary{calc}

% --- Color palette ---------------------------------------------------
\definecolor{cvAccent}{HTML}{2C2C2C}
\definecolor{cvTopBar}{HTML}{1A1A1A}
\definecolor{cvRule}{HTML}{C8C8C8}
\definecolor{cvChipBg}{HTML}{E8E8E8}
\definecolor{cvText}{HTML}{1A1A1A}
\definecolor{cvMuted}{HTML}{6E6E6E}
\definecolor{cvDot}{HTML}{1A1A1A}
\definecolor{cvDotEmpty}{HTML}{C8C8C8}
\definecolor{cvSideBg}{HTML}{FAFAFA}

\color{cvText}

% --- paracol setup ---------------------------------------------------
\columnratio{0.30}
\setlength{\columnsep}{1.2em}
\globalcounter*

% --- hyperref ---------------------------------------------------------
\hypersetup{
  colorlinks=true,
  linkcolor=cvText,
  urlcolor=cvText,
  citecolor=cvText,
  pdfborder={0 0 0}
}

% --- List styling -----------------------------------------------------
\setlist{nosep,leftmargin=1.2em}
\setlist[itemize,1]{label=\textbullet,labelsep=.5em}
\setlist[itemize,2]{label=\textopenbullet,labelsep=.5em,leftmargin=1.2em}

% --- Page background: top banner + sidebar tint -----------------------
\newcommand{\cv@bannerheight}{0.9cm}
\newcommand{\cv@sidebarwidthratio}{0.30}

\newcommand{\cvtopbanner}{%
  \AddToShipoutPictureBG*{%
    \begin{tikzpicture}[remember picture,overlay]
      % Sidebar background tint (full page height, beneath banner)
      \fill[cvSideBg]
        (current page.north west)
        rectangle ([xshift=\cv@sidebarwidthratio\paperwidth]current page.south west);
      % Top banner (full width)
      \fill[cvTopBar]
        (current page.north west)
        rectangle ([yshift=-\cv@bannerheight]current page.north east);
    \end{tikzpicture}%
  }%
}

% --- Section heading font (letter-spaced uppercase) -------------------
\newfontfamily\cv@headingfont{Fira Sans}[
  UprightFeatures={LetterSpace=2.0},
  BoldFeatures={LetterSpace=2.0},
  Scale=1.0
]
\newcommand{\cv@headstyle}[1]{{\cv@headingfont\bfseries\MakeUppercase{#1}}}

% --- Private helper: vertical accent bar -----------------------------
\newcommand{\cv@accentbar}{%
  \tikz[baseline=(b.base)]{
    \node[inner sep=0pt,outer sep=0pt] (b) {\strut};
    \fill[cvAccent]
      ([yshift=-0.15em]b.south west)
      rectangle ([xshift=2.5pt,yshift=1.15em]b.south west);
  }%
}

% --- Private helper: rounded chip pill -------------------------------
\newcommand{\cv@chip}[1]{%
  \tikz[baseline=(c.base)]{
    \node[rounded corners=4pt,fill=cvChipBg,inner xsep=8pt,inner ysep=4pt,
          font=\small,text=cvText] (c) {#1};
  }%
}

% --- Private helper: 5-dot proficiency widget -----------------------
% #1 = filled count (0..5)
\newcommand{\cv@drawdots}[1]{%
  \begin{tikzpicture}[baseline=-0.6ex,x=0.9em]
    \foreach \i in {1,...,5}{%
      \ifnum\i>#1\relax
        \fill[cvDotEmpty] (\i,0) circle (0.28em);
      \else
        \fill[cvDot] (\i,0) circle (0.28em);
      \fi
    }
  \end{tikzpicture}%
}

% =====================================================================
%  PUBLIC API
% =====================================================================

% --- \cvphoto{path}[width] -------------------------------------------
% Rounded-corner sidebar photo. Default width = full column width.
\newcommand{\cvphoto}[2][\linewidth]{%
  \begin{tikzpicture}
    \clip[rounded corners=6pt] (0,0) rectangle (#1,#1*1.2);
    \node[anchor=south west,inner sep=0pt] at (0,0)
      {\includegraphics[width=#1]{#2}};
  \end{tikzpicture}%
}

% --- \cvcontact{icon}{text} ------------------------------------------
% A single contact row: icon on the right, text on the left, baseline aligned.
\newcommand{\cvcontact}[2]{%
  \noindent\makebox[\linewidth][r]{%
    \small #2\hspace{0.6em}%
    \tikz[baseline=-0.6ex]{\node[circle,fill=cvAccent,inner sep=2pt,
                                 text=white,font=\scriptsize] {#1};}%
  }\par\smallskip
}

% --- \cvname{firstline}{secondline} ----------------------------------
% Main column header. First line large bold uppercase; second line small.
\newcommand{\cvname}[2]{%
  {\cv@headingfont\bfseries\fontsize{22pt}{26pt}\selectfont\MakeUppercase{#1}}\par
  \vspace{0.2em}
  {\cv@headingfont\fontsize{11pt}{13pt}\selectfont\MakeUppercase{#2}}\par
  \vspace{0.8em}
}

% --- \cvsummary{text} ------------------------------------------------
\newcommand{\cvsummary}[1]{%
  {\small #1}\par\vspace{0.6em}
  {\color{cvRule}\hrule height 0.4pt}\vspace{0.8em}
}

% --- \cvsection{TITLE} -----------------------------------------------
% Main-column heading with left vertical accent bar.
\newcommand{\cvsection}[1]{%
  \vspace{0.6em}%
  \noindent
  \makebox[0pt][l]{\hspace*{-0.6em}\cv@accentbar}%
  {\cv@headingfont\bfseries\fontsize{13pt}{15pt}\selectfont\MakeUppercase{#1}}%
  \par\vspace{0.4em}
}

% --- \cvsidesection{TITLE} -------------------------------------------
% Sidebar heading (same font, no accent bar).
\newcommand{\cvsidesection}[1]{%
  \vspace{0.6em}%
  {\cv@headingfont\bfseries\fontsize{12pt}{14pt}\selectfont\MakeUppercase{#1}}%
  \par\vspace{0.3em}
}

% --- \cventry{title}{date}{employer}{desc} ---------------------------
% Job/education entry. Title bold uppercase, date right-aligned;
% employer italic muted; desc regular body.
\newcommand{\cventry}[4]{%
  \vspace{0.4em}%
  \noindent
  \begin{tabularx}{\linewidth}{@{}X r@{}}
    {\bfseries\small\MakeUppercase{#1}} & {\small #2}
  \end{tabularx}\par
  {\small\itshape\color{cvMuted} #3}\par
  \vspace{0.2em}
  {\small #4}\par
  \vspace{0.4em}
}

% --- \cvsubentry{date}{title}{desc} ----------------------------------
% Nested sub-project under a job entry.
\newcommand{\cvsubentry}[3]{%
  \vspace{0.2em}%
  {\small #1 \textbar{} \textit{#2}}\par
  \vspace{0.1em}
  \begingroup
    \setlist[itemize,1]{label=\textopenbullet,leftmargin=1.4em,labelsep=.4em}
    #3
  \endgroup
  \vspace{0.3em}
}

% --- \cvchip{label} and \cvchiprow{labels} ---------------------------
\newcommand{\cvchip}[1]{\cv@chip{#1}}

% \cvchiprow stacks chips vertically (one per line, centered).
\newcommand{\cvchiprow}[1]{%
  \begingroup
  \def\@cvchipsep{}%
  \@for\@chip:=#1\do{%
    \@cvchipsep
    \par\centering\cv@chip{\@chip}%
    \def\@cvchipsep{\par\vspace{0.3em}}%
  }%
  \par\medskip
  \endgroup
}

% --- \cvskillgroup{heading}{body} ------------------------------------
\newcommand{\cvskillgroup}[2]{%
  \vspace{0.3em}%
  {\bfseries\small #1}\par
  {\small\color{cvText} #2}\par
  \vspace{0.3em}
}

% --- \cvlanguage{name}{sublabel}{level} ------------------------------
% Language row: name bold, small sublabel below, 5-dot rating on right.
\newcommand{\cvlanguage}[3]{%
  \noindent
  \begin{tabularx}{\linewidth}{@{}X r@{}}
    \begin{tabular}[t]{@{}l@{}}
      {\bfseries\small #1}\\
      {\scriptsize\color{cvMuted} #2}
    \end{tabular}
    & \cv@drawdots{#3}
  \end{tabularx}\par
  \vspace{0.3em}
}

% --- \cvsidelist{items} ----------------------------------------------
% Plain bullet list for sidebar. Pass complete \item lines as #1.
\newcommand{\cvsidelist}[1]{%
  \begingroup
  \setlist[itemize,1]{label={},leftmargin=0pt,labelsep=0pt}
  \begin{itemize}
    #1
  \end{itemize}
  \endgroup
}

% --- \cvruled --------------------------------------------------------
\newcommand{\cvruled}{%
  \par\vspace{0.4em}%
  {\color{cvRule}\hrule height 0.3pt}%
  \par\vspace{0.4em}
}

\endinput

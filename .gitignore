# Generated CV variant tree (regenerated by CI / local build via cv/generate).
# Never commit generated LaTeX bodies, per-leaf mains, personal-info, or engine
# selectors — the data/*.yml sources + templates/ + styles/ are the truth.
/cvs/

# cv-academics contains critical PII, MUST not be pushed to remote repository
data/cv-academics.yml

# Local-only build-matrix overlay generated by `task cv:academics`. It
# re-enables the PII-bearing cv-academics variant for local gh act runs;
# MUST never be committed.
data/variants.local.yml

